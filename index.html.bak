const VISIBLE=5;let expanded=false;
function lang(){return document.documentElement.lang}
function splitTags(s){const out=[];let buf='',d=0;
  for(let i=0;i<s.length;i++){const c=s[i];
    if(c==='(')d++;else if(c===')')d=Math.max(0,d-1);
    if(d===0&&(c==='·'||c===',')){out.push(buf.trim());buf='';continue;}
    buf+=c;}
  if(buf.trim())out.push(buf.trim());
  return out.filter(Boolean);}
function renderSkills(){const g=document.getElementById('skillgrid');g.innerHTML='';
  SKILLS.forEach(s=>{const d=s[lang()];const el=document.createElement('div');el.className='skill reveal'+(s.feat?' feat':'');
    const tags=splitTags(d[1]).map(t=>`<span class="tag">${t}</span>`).join('');
    el.innerHTML=`<h3><span class="i">${s.ic}</span>${d[0]}</h3><div class="tags">${tags}</div>`;g.appendChild(el);});}
function renderJobs(){const t=document.getElementById('timeline');t.innerHTML='';
  JOBS.forEach((j,i)=>{const el=document.createElement('div');el.className='job reveal';
    if(!expanded&&i>=VISIBLE)el.style.display='none';
    const cp=j.co.split(' — ');const co='<b>'+cp[0]+'</b>'+(cp[1]?'<span class="proj"> — '+cp.slice(1).join(' — ')+'</span>':'');
    const bl=j.b[lang()].map(x=>`<li>${x}</li>`).join('');
   